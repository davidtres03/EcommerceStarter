<Page x:Class="EcommerceStarter.Installer.Views.UpgradeProgressPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Upgrading...">
    
    <Grid>
        <!-- Progress Panel -->
        <StackPanel x:Name="ProgressPanel" MaxWidth="600" VerticalAlignment="Center" Margin="40">
            <TextBlock Text="⬆️ Upgrading..." 
                      FontSize="32"
                      FontWeight="Bold"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,30"/>
            
            <ProgressBar x:Name="ProgressBar" 
                        Height="30" 
                        Minimum="0" 
                        Maximum="100"
                        Margin="0,0,0,20"/>
            
            <TextBlock x:Name="StepText"
                      Text="Initializing..."
                      FontSize="14"
                      Foreground="Gray"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,10"/>
            
            <TextBlock x:Name="StatusText"
                      Text="Starting upgrade process..."
                      FontSize="16"
                      FontWeight="SemiBold"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,20"/>
            
            <ScrollViewer Height="150" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="DetailText"
                          Text=""
                          FontSize="12"
                          Foreground="Gray"
                          TextWrapping="Wrap"
                          FontFamily="Consolas"/>
            </ScrollViewer>
        </StackPanel>
        
        <!-- Result Panel (Hidden initially) -->
        <StackPanel x:Name="ResultPanel" MaxWidth="600" VerticalAlignment="Center" Margin="40" Visibility="Collapsed">
            <TextBlock x:Name="ResultIcon"
                      Text="?"
                      FontSize="72"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,20"/>
            
            <TextBlock x:Name="ResultTitle"
                      Text="Success!"
                      FontSize="28"
                      FontWeight="Bold"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,20"/>
            
            <TextBlock x:Name="ResultMessage"
                      Text="Upgrade completed successfully!"
                      FontSize="16"
                      TextWrapping="Wrap"
                      HorizontalAlignment="Center"
                      TextAlignment="Center"
                      Margin="0,0,0,30"/>
            
            <Button x:Name="CloseButton"
                   Content="Close"
                   Click="CloseButton_Click"
                   MinWidth="140"
                   HorizontalAlignment="Center"
                   Padding="15,8"/>
        </StackPanel>
    </Grid>
</Page>
