<Page x:Class="EcommerceStarter.Installer.Views.RepairPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Repair Installation"
      Background="White">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="40"
                    MaxWidth="800">

            <!-- Title -->
            <StackPanel Margin="0,0,0,30">
                <TextBlock Text="🔧 Repair Installation"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>
                <TextBlock Text="Verify and repair your installation"
                           FontSize="14"
                           Foreground="#666666"/>
            </StackPanel>

            <!-- Status Container -->
            <Border Background="#F8F9FA"
                    BorderBrush="#DEE2E6"
                    BorderThickness="1"
                    Padding="25"
                    CornerRadius="8"
                    Margin="0,0,0,30">
                <StackPanel>
                    <TextBlock Text="Repair Status"
                               FontWeight="SemiBold"
                               FontSize="16"
                               Margin="0,0,0,20"/>

                    <!-- Repair Steps -->
                    <StackPanel>
                        <!-- Check Files -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="✓"
                                       FontSize="20"
                                       Foreground="#4CAF50"
                                       VerticalAlignment="Top"
                                       Margin="0,2,12,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Verify Application Files"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="All application files present and valid"
                                           FontSize="13"
                                           Foreground="#666666"/>
                            </StackPanel>
                        </Grid>

                        <!-- Check IIS -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="✓"
                                       FontSize="20"
                                       Foreground="#4CAF50"
                                       VerticalAlignment="Top"
                                       Margin="0,2,12,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="IIS Configuration"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Website and app pool properly configured"
                                           FontSize="13"
                                           Foreground="#666666"/>
                            </StackPanel>
                        </Grid>

                        <!-- Check Database -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="✓"
                                       FontSize="20"
                                       Foreground="#4CAF50"
                                       VerticalAlignment="Top"
                                       Margin="0,2,12,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Database Connection"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Database connection verified and accessible"
                                           FontSize="13"
                                           Foreground="#666666"/>
                            </StackPanel>
                        </Grid>

                        <!-- Check Permissions -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="✓"
                                       FontSize="20"
                                       Foreground="#4CAF50"
                                       VerticalAlignment="Top"
                                       Margin="0,2,12,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="File Permissions"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="All required permissions are correctly set"
                                           FontSize="13"
                                           Foreground="#666666"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Repair Result -->
            <Border Background="#D1F2EB"
                    BorderBrush="#48C9B0"
                    BorderThickness="1"
                    Padding="20"
                    CornerRadius="8"
                    Margin="0,0,0,30">
                <StackPanel>
                    <TextBlock Text="✓ Installation Status: Healthy"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#0D5E4F"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="No issues found. Your installation is in good working order."
                               FontSize="13"
                               Foreground="#0D5E4F"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Next Steps -->
            <TextBlock Text="Next Steps"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,15"/>
            <TextBlock Text="• Your application is ready to use"
                       FontSize="13"
                       Foreground="#666666"
                       Margin="0,0,0,8"/>
            <TextBlock Text="• If you're experiencing issues, try restarting IIS"
                       FontSize="13"
                       Foreground="#666666"
                       Margin="0,0,0,8"/>
            <TextBlock Text="• Contact support if problems persist"
                       FontSize="13"
                       Foreground="#666666"
                       Margin="0,0,0,30"/>

        </StackPanel>
    </ScrollViewer>

</Page>
